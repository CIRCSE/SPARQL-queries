PREFIX lila: <http://lila-erc.eu/ontologies/lila/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX dc: <http://purl.org/dc/elements/1.1/>
PREFIX powla: <http://purl.org/powla/powla.owl#>
PREFIX annales: <http://lila-erc.eu/data/corpora/QuintusEnniusOperaOmnia/id/corpus/Annales/>
PREFIX pharsalia: <http://lila-erc.eu/data/corpora/CIRCSELatinLibrary/id/corpus/Pharsalia/>

SELECT ?lemma ?lemmaLabel ?tokensAnnales ?tokensAnnalesRelFreq ?tokensPharsalia ?tokensPharsaliaRelFreq ?DIFF
WHERE {
  # 1. Retrieves all unique lemmas and their corresponding labels from both corpora.
  {
    SELECT DISTINCT ?lemma ?lemmaLabel
    WHERE {
      ?lemma rdfs:label ?lemmaLabel .
      { ?tokenA powla:hasLayer annales:DocumentLayer ; lila:hasLemma ?lemma . }
      UNION
      { ?tokenP powla:hasLayer pharsalia:DocumentLayer ; lila:hasLemma ?lemma . }
    }
  }

  # 2. Subquery for the lemma count in the Annales; returns 0 when the lemma does not occur.
  OPTIONAL {
    SELECT ?lemma (COUNT(?tokenAnnales) AS ?cntAnnales)
    WHERE {
      ?tokenAnnales powla:hasLayer annales:DocumentLayer ;
                    lila:hasLemma ?lemma .
    }
    GROUP BY ?lemma
  }

  # 3. Subquery for the lemma count in the Pharsalia; returns 0 when the lemma does not occur.
  OPTIONAL {
    SELECT ?lemma (COUNT(?tokenPharsalia) AS ?cntPharsalia)
    WHERE {
      ?tokenPharsalia powla:hasLayer pharsalia:DocumentLayer ;
                      lila:hasLemma ?lemma .
    }
    GROUP BY ?lemma
  }

  # Handling missing values (converts empty/unbound values to 0)
  BIND(COALESCE(?cntAnnales, 0) AS ?tokensAnnales)
  BIND(COALESCE(?cntPharsalia, 0) AS ?tokensPharsalia)
  
  # Computes the relative frequency of each lemma as a percentage of the total tokens in the Annales.
  BIND((?tokensAnnales * 100.0) / 3485 AS ?tokensAnnalesRelFreq)
  
  # Computes the relative frequency of each lemma as a percentage of the total tokens in the Pharsalia.
  BIND((?tokensPharsalia * 100.0) / 53340 AS ?tokensPharsaliaRelFreq)
  
  # Computes the difference in percentage relative frequency between the Pharsalia and the Annales (Pharsalia minus Annales).
  BIND(?tokensPharsaliaRelFreq - ?tokensAnnalesRelFreq AS ?DIFF)
  
}
ORDER BY DESC (?DIFF)
